using { /Verse.org/Tests/VerseTestScriptCmd }

# No <decides>
assert_semantic_error(3512):
    F(X:int, Xs:[]int):int = first(I->Y:Xs; X = Y){I}

# Missing {expr}
assert_semantic_error(3502):
    F(X:int, Xs:[]int)<decides>:int = first(I->Y:Xs; X = Y)

# Not yet
assert_semantic_error(3605):
    F(X:int, Xs:[]int)<decides>:int = first{I->Y:Xs; X = Y; I}

# Only allow expressions that can fail (same as `for`)
assert_semantic_error(3513):
    F(X:int, Xs:[]int)<decides>:int = first(I->Y:Xs; X = Y; I){I}

# Empty {} is ok
F(X:int, Xs:[]int)<decides>:void = first(I->Y:Xs; X = Y) {}

# Three different ways to write first
FirstPosDecide(X:int, Xs:[]int)<transacts><decides>:int =
    first(I->Y:Xs; X = Y){I}

FirstPosDecideDo(X:int, Xs:[]int)<transacts><decides>:int = 
    first:
        I->Y:Xs
        X = Y
    do:
        I
FirstPosDecideDot(X:int, Xs:[]int)<transacts><decides>:int = 
    first(I->Y:Xs; X = Y). I

assert:
    not FirstPosDecide[1, array{}]
    FirstPosDecide[2,array{1,2,3}] = 1
    not FirstPosDecide[4,array{1,2,3}]

    not FirstPosDecideDo[1, array{}]
    FirstPosDecideDo[2,array{1,2,3}] = 1
    not FirstPosDecideDo[4,array{1,2,3}]

    not FirstPosDecideDot[1, array{}]
    FirstPosDecideDot[2,array{1,2,3}] = 1
    not FirstPosDecideDot[4,array{1,2,3}]



FirstPosUsingDecide(X:int, Xs:[]int):int =
   if(Z:=FirstPosDecide[X, Xs]) { Z }
   else { -1 }

assert:
    FirstPosUsingDecide(2,array{}) = -1
    FirstPosUsingDecide(2,array{1,2,3}) = 1
    FirstPosUsingDecide(4,array{1,2,3}) = -1


FirstPos(X:int, Xs:[]int):int =
   if(Z:=first(I->Y:Xs; X = Y){I}) {Z}
   else { -1 }

assert:
    FirstPos(2,array{}) = -1
    FirstPos(2,array{1,2,3}) = 1
    FirstPos(4,array{1,2,3}) = -1

# Workaround since 'for', and therefore also 'first', doesn't allow non failing expressions as filters 
value := class:
    var V:int = 1
    Set(W:int)<decides><transacts>:int =
        set V = W
    Inc()<decides><transacts>:int =
        set V += 1

# Verify rollback
FirstPos2(X:int, Xs:[]int):tuple(int, int) =
    W : value = value{V := 0}
    if(Z:=first(I->Y:Xs; W.Inc[]; X = Y){I}):
        (Z, W.V)
    else:
        (-1, W.V)

assert:
    FirstPos2(20, array{}) = (-1, 0)
    Xs := array{10,20,30,20}
    FirstPos2(20, Xs) = (1, 1)
    FirstPos2(21, Xs) = (-1, 0)

# Nested iterations with check for rollback
FirstPos6(X:int, Xss:[][]int):tuple(tuple(int, int), int, int) =
    Count0 : value =  value{V := 0}
    Count1 : value =  value{V := 0}
    if(Z := first(I0->Xs:Xss; Count0.Inc[]; I1->Y:Xs; Count1.Inc[]; X = Y){(I0, I1)}):
        (Z, Count0.V, Count1.V)
    else:
        ((-1, -1), Count0.V, Count1.V)

assert:
    FirstPos6(20, array{}) = ((-1, -1), 0, 0)
    FirstPos6(20, array{array{}}) = ((-1, -1), 0, 0)
    Xss := array{
            array{10,20,30,20},
            array{30,40,50,40}
          }
    FirstPos6(20, Xss) = ((0, 1), 1, 1)
    verse_vm_only{ FirstPos6(50, Xss) = ((1, 2), 1, 1) }
    bp_vm_only{ FirstPos6(50, Xss) = ((1, 2), 2, 1) } # This is a bug, the same bug exist in for
    FirstPos6(21, Xss) = ((-1, -1), 0, 0)


# Nested iterations, possible failures in result of first
First7(X:int, Xss:[][]int)<decides><transacts>:tuple(int, int) =
    first(I0->Xs:Xss; I1->Y:Xs; X = Y){I0 <> I1; (I0, I1)}

assert:
    not First7[20, array{}]
    not First7[20, array{array{}}]
    Xss := array{
            array{10,20,30,20},
            array{30,40,50,40}
          }
    First7[20, Xss] = (0, 1)
    not First7[40, Xss]  # Fails I0 <> I1 test
    not First7[21, Xss]

# Value must be in both list, and with a lower index in Xs
Function1(Xs:[]int, Ys:[]int)<decides><transacts>:int =
    first(IX->X:Xs; first(IY->Y:Ys; X = Y; IX < IY){ IY }){X}

assert:
    not Function1[array{}, array{}]
    not Function1[array{1, 2, 4}, array{2, 4}]
    Function1[array{1, 2, 4}, array{1, 4, 2}] = 2
    Function1[array{1, 2, 4}, array{1, 2, 2}] = 2


# Noticed some problems with live variables and for while implementing if with iterators.
# Should work now.
verse_vm_only {
    
assert:
    A:value = value{}
    var live B:int = 10+A.V
    Result:[]int = for (X:=1..3; A.Set[X]; B = 10+X):
                        B
    Result = array{11,12,13}

assert:
    A:value = value{}
    Result:[]int = for (X:=1..3; var live B:int = 10*X+A.V; A.Set[X]; B = 10*X+X):
                        B
    Result = array{11,22,33}               
}




