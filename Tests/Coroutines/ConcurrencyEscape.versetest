    Tick(2)
    AssertLog(",bzY,a3c,,", ?BPVM := ",bzcaY,,,")


### self-cancellation tests
###
SelfCancelSync(Arm1:arm, Arm2:arm, Arm3:noreturn_arm)<suspends>:string =
    defer { Log("z") }
    Event:event() = event(){}
    R :=
        sync:
            block:
                defer { Log("a") }
                Wait(Arm1.Delay)
                Event.Await()
                if (V := Arm1.Return?):
                    return V
                Log("1")
                1
            block:
                defer { Log("b") }
                Wait(Arm2.Delay)
                Event.Signal()
                if (V := Arm2.Return?):
                    return V
                Log("2")
                2
            block:
                defer { Log("c") }
                Wait(Arm3.Delay)
                Log("3")
                3

    "({R(0)}|{R(1)}|{R(2)})"

assert:
    spawn{Test(SelfCancelSync, 1, (arm{Delay := 1}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",1a2b3cz(1|2|3),,")
assert:
    spawn{Test(SelfCancelSync, 1, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",ac2bzX,,", ?BPVM := ",azcX,2b,")
assert:
    spawn{Test(SelfCancelSync, 1, (arm{Delay := 1}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",1abczY,,", ?BPVM := ",1abzcY,,")
assert:
    spawn{Test(SelfCancelSync, 1, (arm{Delay := 2, Return := option{"X"}}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",bcazY,,", ?BPVM := ",bzcaY,,")
assert:
    spawn{Test(SelfCancelSync, 1, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",acbzX,,", ?BPVM := ",azcX,bz,")

