    spawn{Test(Rush, 2, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",azX,2b3c,,", ?BPVM := ",azcbX,,,")
