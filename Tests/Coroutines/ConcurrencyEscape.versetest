assert:
    spawn{Test(Rush, 2, (arm{Delay := 1}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",1az(1),2b3c,,", ?BPVM := ",1azcb(1),,,")
