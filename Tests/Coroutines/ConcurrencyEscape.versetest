using { /Verse.org/Tests/VerseTestScriptCmd }

Log(Msg:string):void = { CoroUtils.LogEvent(Msg); }
GetLogStr():string = CoroUtils.GetEventLogString()
Wait(Ticks:int)<suspends>:void = CoroUtils.WaitTicks(Ticks)
Tick(Ticks:int):void = CoroUtils.Tick(Ticks)
AssertLog(VVM:string, ?BPVM:string := VVM):void =
    Actual := CoroUtils.GetEventLogString()
    verse_vm_only { Expected := VVM }
    bp_vm_only { Expected := BPVM }
    if (not Actual = Expected):
        Err("expected \"{Expected}\", but got: \"{Actual}\"")

arm := struct:
    Delay:int
    Return:?string = false

noreturn_arm := struct:
    Delay:int

Test(F:type{_(:arm, :arm, :noreturn_arm)<suspends>:string}, Ticks:int, Args:tuple(arm, arm, noreturn_arm))<suspends>:void =
    R := F(Args)
    Log(R)
    Tick(Ticks)

### basic tests
###
Sync(Arm1:arm, Arm2:arm, Arm3:noreturn_arm)<suspends>:string =
    defer { Log("z") }
    R :=
        sync:
            block:
                defer { Log("a") }
                Wait(Arm1.Delay)
                if (V := Arm1.Return?):
                    return V
                Log("1")
                1
            block:
                defer { Log("b") }
                Wait(Arm2.Delay)
                if (V := Arm2.Return?):
                    return V
                Log("2")
                2
            block:
                defer { Log("c") }
                Wait(Arm3.Delay)
                Log("3")
                3

    "({R(0)}|{R(1)}|{R(2)})"

assert:
    spawn{Test(Sync, 1, (arm{Delay := 1}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",1a2b3cz(1|2|3),,")
assert:
    spawn{Test(Sync, 1, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",acbzX,,", ?BPVM := ",azcbX,,")
assert:
    spawn{Test(Sync, 1, (arm{Delay := 1}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",1abczY,,", ?BPVM := ",1abzcY,,")
assert:
    spawn{Test(Sync, 1, (arm{Delay := 2, Return := option{"X"}}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",bcazY,,", ?BPVM := ",bzcaY,,")
assert:
    spawn{Test(Sync, 1, (arm{Delay := 1, Return := option{"X"}}, arm{Delay := 1, Return := option{"Y"}}, noreturn_arm{Delay := 1}))}
    Tick(2)
    AssertLog(",acbzX,,", ?BPVM := ",azcbX,,")

