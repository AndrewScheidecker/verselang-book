assert_semantic_error(2304):
    vpackage(P, /Verse.org/A, ?Scope:=PublicAPI, ?AllowExperimental:=false):
        snippet:
            base_class := class:
                @experimental
                Field:int=0
            sub_class := class(base_class):
                Field<override>:int=1

assert_semantic_error(2304):
    vpackage(P, /Verse.org/A, ?Scope:=PublicAPI, ?AllowExperimental:=false):
        snippet:
            base_class := class:
                @experimental
                Method():void={}
            sub_class := class(base_class):
                Method<override>():void={}

assert_semantic_error(2304):
    vpackage(P, /Verse.org/A, ?Scope:=PublicAPI, ?AllowExperimental:=false):
        snippet:
            base_class := class:
                @experimental
                Field:int=0
            F():void=base_class{Field:=1}

assert_valid:
    vpackage(P, /Verse.org/A, ?Scope:=PublicAPI, ?AllowExperimental:=false):
        snippet:
            @experimental
            my_class := class:
                X:my_class # should be allowed because it's a use of my_class inside my_class.