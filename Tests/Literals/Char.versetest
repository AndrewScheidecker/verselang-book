RequireChar32Equal(Lhs:char32, Rhs:char32)<computes><decides>:void=
    if (Lhs <> Rhs):
        DebugPrint("RequireChar32Equal: {Lhs} \<\> {Rhs}")
        false?
TestChar32Literal(UnicodeCodePoint:int, HexLiteral:char32, CodeUnitLiteral:?char, PrintableLiteral:?char32)<computes><decides>:void=
    RequireChar32Equal[HexLiteral, ToChar32(UnicodeCodePoint)]
    if (CodeUnitChar := CodeUnitLiteral?):
        ToString(HexLiteral) = ToString(CodeUnitChar)
    if (PrintableLiteralChar := PrintableLiteral?):
        RequireChar32Equal[HexLiteral, PrintableLiteralChar]

assert{TestChar32Literal[0x00000, 0u00000, option{0o00}, false]}
assert{TestChar32Literal[0x0007f, 0u0007f, option{0o7f}, false]}
assert{TestChar32Literal[0x00080, 0u00080, false, false]}
assert{TestChar32Literal[0x00081, 0u00081, false, false]}
assert{TestChar32Literal[0x000a0, 0u000a0, false, false]}
assert{TestChar32Literal[0x000ff, 0u000ff, false, false]}
assert{TestChar32Literal[0x007FF, 0u007FF, false, option{'߿'}]}
assert{TestChar32Literal[0x00800, 0u00800, false, option{'ࠀ'}]}
assert{TestChar32Literal[0x0597d, 0u0597d, false, option{'好'}]}
assert{TestChar32Literal[0x10000, 0u10000, false, option{'𐀀'}]}
assert{TestChar32Literal[0x1f600, 0u1f600, false, option{'😀'}]}
assert{TestChar32Literal[0x1f680, 0u1f680, false, option{'🚀'}]}
assert{TestChar32Literal[0x10ffff, 0u10ffff, false, false]}
