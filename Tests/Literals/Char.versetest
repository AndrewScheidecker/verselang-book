using { /Verse.org/Tests/VerseTestScriptCmd }

# Test that empty character literals produce a syntax error.
assert_syntax_error(3100){"\'\'"}

# Multi-character character literals produce a syntax error.
assert_syntax_error(3100){"\'ab\'"}
assert_syntax_error(3100){"\'01\'"}
assert_syntax_error(3100){"\'\{0o00\}\{0o01\}\'"}
assert_syntax_error(3100){"\'abcdefghijklmnopqrstuvwxyz\'"}

# Non-hexadecimal characters in hex character literals should be a syntax error.
assert_valid_syntax      {"0off"}
assert_valid_syntax      {"0oFF"}
assert_syntax_error(3100){"0ofg"}
assert_syntax_error(3100){"0ufg"}

# Overlong hex character literals should be a syntax error.
assert_syntax_error(3100){"0o000"}
assert_syntax_error(3100){"0offf"}
assert_syntax_error(3100){"0o000000"}
assert_syntax_error(3100){"0offffff"}

assert_syntax_error(3100){"0uffffff"}
assert_syntax_error(3100){"0u000000000"}
assert_syntax_error(3100){"0ufffffffff"}

# Invalid escape sequences in character literals.
assert_syntax_error(3100){"\'\\x\'"}
assert_syntax_error(3100){"\'\\z\'"}
assert_syntax_error(3100){"\'\\1\'"}
assert_syntax_error(3100){"\'\\a\'"}
assert_syntax_error(3100){"\'\\b\'"}

# Uppercase prefix (0O and 0U) - not supported.
assert_syntax_error(3101){"0O41"}
assert_syntax_error(3101){"0OFF"}
assert_syntax_error(3101){"0U10000"}
assert_syntax_error(3101){"0U0597d"}

# Unicode code point out of range (above 0x10ffff).
assert_syntax_error(3100){"0u110000"}
assert_syntax_error(3100){"0u200000"}
assert_syntax_error(3100){"0uffffff"}

# Surrogate code points (U+D800-U+DFFF) are invalid Unicode scalar values.
# These are rejected at the parse level as syntax errors.
assert_syntax_error(3110){"0uD800"}   # First high surrogate
assert_syntax_error(3110){"0uDBFF"}   # Last high surrogate
assert_syntax_error(3110){"0uDC00"}   # First low surrogate
assert_syntax_error(3110){"0uDFFF"}   # Last low surrogate

# Surrogates in strings are also rejected at parse time.
assert_syntax_error(3110){"\"\{0uD800\}\""}
assert_syntax_error(3110){"\"hello\{0uD800\}world\""}

# Even valid UTF-16 surrogate pairs are rejected - each code point must be
# a valid Unicode scalar value individually.
assert_syntax_error(3110){"\"\{0uD834\}\{0uDD1E\}\""}  # Would encode U+1D11E in UTF-16

# Unicode non-characters are valid Unicode scalar values (unlike surrogates).
# All non-characters are allowed: FFFE/FFFF variants and the FDD0-FDEF range.
assert_valid{X:char32 = 0uFFFE}                   # BMP non-character
assert_valid{X:char32 = 0uFFFF}                   # BMP non-character
assert_valid{X:char32 = 0uFDD0}                   # Non-character range start
assert_valid{X:char32 = 0uFDEF}                   # Non-character range end

# Test the mapping between codepoints and source code characters.
RequireChar8Equal(Lhs:char, Rhs:char)<computes><decides>:void=
    if (Lhs <> Rhs):
        DebugPrint("RequireChar8Equal: {Lhs} \<\> {Rhs}")
        false?

TestChar8Literal(Utf8CodeUnit:int, HexLiteral:char, UnicodeLiteral:?char32, PrintableLiteral:?char, EscapedLiteral:?char)<computes><decides>:void=
    RequireChar8Equal[HexLiteral, ToChar(Utf8CodeUnit)]
    if (UnicodeLiteralChar := UnicodeLiteral?):
        ToString(HexLiteral) = ToString(UnicodeLiteralChar)
    if (PrintableLiteralChar := PrintableLiteral?):
        RequireChar8Equal[HexLiteral, PrintableLiteralChar]
    if (EscapedLiteralChar := EscapedLiteral?):
        RequireChar8Equal[HexLiteral, EscapedLiteralChar]

assert{TestChar8Literal[0x00, 0o00, option{0u00}, false, false]}
assert{TestChar8Literal[0x01, 0o01, option{0u01}, false, false]}
assert{TestChar8Literal[0x02, 0o02, option{0u02}, false, false]}
assert{TestChar8Literal[0x03, 0o03, option{0u03}, false, false]}
