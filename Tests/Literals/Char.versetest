assert{TestChar8Literal[0x08, 0o08, option{0u08}, false, false]}
assert{TestChar8Literal[0x09, 0o09, option{0u09}, option{'	'}, option{'\t'}]} # Be careful that PrintableLiteral contains an ASCII tab character
assert{TestChar8Literal[0x0a, 0o0a, option{0u0a}, false, option{'\n'}]}
assert{TestChar8Literal[0x0b, 0o0b, option{0u0b}, false, false]}
