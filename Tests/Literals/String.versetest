# Empty string tests.
assert{"" = ""}
assert{"" = "{}"}
assert{"" = "{""}"}
assert{"".Length = 0}

# Strings with embedded null bytes.
assert{"{0o00}".Length = 1}
assert{"a{0o00}b".Length = 3}
assert{"{0o00}{0o00}{0o00}".Length = 3}
assert{"{0o00}abc".Length = 4}
assert{"abc{0o00}".Length = 4}
assert{"hello{0o00}world".Length = 11}
assert{"{0o00}" <> ""}
assert{"a{0o00}b" <> "ab"}

# Test the mapping between codepoints and source code characters.

assert{" {0o09} " = " 	 "} # Be careful that this contains an ASCII tab character!
assert{" {0o20} " = "   "}
assert{" {0o21} " = " ! "}
assert{" {0o23} " = " # "}
assert{" {0o24} " = " $ "}
assert{" {0o25} " = " % "}
assert{" {0o26} " = " & "}
