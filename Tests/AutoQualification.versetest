assert_auto_qualification(
    vpackage(P0, /A):
      snippet:
        Function(X:int, ?Y:int=0):int = X+Y
        Apply(F:t->u, X:t where t:type, u:type):u = F(X)

        Use():int = 
          Apply(Function, 1)
          Apply(Function, (1, ?Y:=2))
){
(/A:)Function((local:)X:(/Verse.org/Verse:)int, ?Y:(/Verse.org/Verse:)int = 0):(/Verse.org/Verse:)int = 
        (local:)X+Y
(/A:)Apply((local:)F:(local:)t -> (local:)u, (local:)X:(local:)t where (local:)t:(/Verse.org/Verse:)type, (local:)u:(/Verse.org/Verse:)type):(local:)u = 
        (local:)F((local:)X)
(/A:)Use():(/Verse.org/Verse:)int = 
        (/A:)Apply((/A:)Function, 1)
        (/A:)Apply((/A:)Function, (1, ?Y := 2))
}


# Treatment of @doc comments could be improved, but this is ok for the parser. 
assert_auto_qualification(
    vpackage(P0, /Verse.org/Test, ?Scope:=InternalAPI):
      snippet:
        using { /Verse.org/Native }
        @doc("An enum")
        e := enum:
          @doc("First value")
          V1
          @doc("Second value")
          V2
){
using{
    /Verse.org/Native
}

@doc("An enum")
(/Verse.org/Test:)e := 
        enum{
            V1<doc("First value")>
            V2<doc("Second value")>
        }
}


