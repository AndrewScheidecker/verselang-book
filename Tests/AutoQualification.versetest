assert_auto_qualification(
    vpackage(P0, /A):
      snippet:
        m := module:
          Value<public>:int = 42
          Function<public>(X:int):int = Value + X

        Use():int = m.Function(m.Value)
){
(/A:)m := 
        module{
            (/A/m:)Value<public>:(/Verse.org/Verse:)int = 
                    42
            (/A/m:)Function<public>((local:)X:(/Verse.org/Verse:)int):(/Verse.org/Verse:)int = 
                    (/A/m:)Value+(local:)X
        }
(/A:)Use():(/Verse.org/Verse:)int = 
        (/A:)m.(/A/m:)Function((/A:)m.(/A/m:)Value)
}


