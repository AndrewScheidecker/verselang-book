                    (local:)Triple:tuple((/Verse.org/Verse:)int, (/Verse.org/Verse:)int, (/Verse.org/Verse:)int) = (7, -1, -1)
                    3
            (/Path/c:)F2():(/Verse.org/Verse:)int = 
                    (local:)Pair:tuple((/Verse.org/Verse:)int, (/Verse.org/Verse:)int) = (1, 2)
                    2
        }
}

assert_auto_qualification<depends_on_library>(
  vpackage(P0, /M, ?Dependencies:=("Verse/Verse"), ?VerseVersion:=0): 
    snippet:
      F(X:int):[]int :=
        return for(Y:=1..X) do Y
){
(/M:)F(X:(/Verse.org/Verse:)int):[](/Verse.org/Verse:)int = 
        return for(Y := 1 .. X) do{Y }
}

assert_auto_qualification(
    vpackage(P0, /M): 
        snippet:
            c0 := class:
                F():int = 42

            c1 := class(c0):
                F<override>():int = 666
                F(X:int, Y:int):int = X+Y
                H(X:int):int = F(X, X)
){
(/M:)c0 := 
        class{
            (/M/c0:)F():(/Verse.org/Verse:)int = 
                    42
        }
(/M:)c1 := 
        class((/M:)c0){
            (/M/c0:)F<override>():(/Verse.org/Verse:)int = 
                    666
            (/M/c1:)F((local:)X:(/Verse.org/Verse:)int, (local:)Y:(/Verse.org/Verse:)int):(/Verse.org/Verse:)int = 
                    (local:)X+(local:)Y
            (/M/c1:)H((local:)X:(/Verse.org/Verse:)int):(/Verse.org/Verse:)int = 
                    (/M/c1:)F((local:)X, (local:)X)
        }
}


# Despite having a test for named parameters earlier in this file, which passed, this one failed.
assert_auto_qualification(
    vpackage(P0, /A):
      snippet:
        queue(t:type) := class:
            Capacity : ?type {X:int where 1 <= X, X <= 100} = false
            Elements:[]t = array{}
            IsCircular : logic = false    

        CreateQueue<public><constructor>((InitialElements:[]t, ?Capacity : ?type {X:int where 1 <= X, X <= 100} = false, ?IsCircular: logic = false) where t:type) := queue(t):
           Elements := InitialElements
           Capacity := Capacity
           IsCircular := IsCircular
){
(/A:)queue((local:)t:(/Verse.org/Verse:)type) := 
        class{
            (/A/queue:)Capacity:?type{X:(/Verse.org/Verse:)int where 1 <= X, X <= 100 } = 
                    false
            (/A/queue:)Elements:[](local:)t = 
                    array{
                    }
            (/A/queue:)IsCircular:logic = 
                    false
        }
(/A:)CreateQueue<public><constructor>(((local:)InitialElements:[](local:)t, ?Capacity:?type{X:(/Verse.org/Verse:)int where 1 <= X, X <= 100 } = false, ?IsCircular:logic = false) where (local:)t:(/Verse.org/Verse:)type) := 
        (/A:)queue((local:)t){
            Elements := 
                    (local:)InitialElements
            Capacity := 
                    Capacity
            IsCircular := 
                    IsCircular
        }
}
