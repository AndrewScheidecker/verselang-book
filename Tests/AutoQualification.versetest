assert_auto_qualification(
vpackage(P0, /Path):
  snippet:
    c := class:
           F(X:int):void =
             if (X=0):
               if(X=1):
               else if:
                 X = 2
               then:
               else. 3
             else. 4
){
(/Path:)c := 
        class{
            (/Path/c:)F((local:)X:(/Verse.org/Verse:)int):void = 
                    
                    if{
                        (local:)X = 0
                    }
                    then {
                        
                        if{
                            (local:)X = 1
                        }
                        then {
                        }
                        else if {
                            (local:)X = 2
                        }
                        then {
                        }
                        else {
                            3
                        }
                    }
                    else {
                        4
                    }
        }
}

