# Found in the wild

# The problem here was that the "_ =>" doesn't get any following newlines,
# and "_ => {}; set _Value = NewValue" does not compile.
assert_auto_qualification(
vpackage(P0, /C):
  snippet:
    value := class:
      var A:int = 0
      var B:int = 0

    c := class:
      var _Value:value = value{} 
      SetValue(MemberName:[]char, MemberValue:int):void = 
        var NewValue:value = _Value; case(MemberName):
            "A" => set NewValue.A = MemberValue
            "B" => set NewValue.B = MemberValue
            _ =>
        set _Value = NewValue
){
(/C:)value := 
        class{
            var (/C/value:)A:(/Verse.org/Verse:)int = 
                    0
            var (/C/value:)B:(/Verse.org/Verse:)int = 
                    0
        }
(/C:)c := 
        class{
            var (/C/c:)_Value:(/C:)value = 
                    (/C:)value{
                    }
            (/C/c:)SetValue((local:)MemberName:[]char, (local:)MemberValue:(/Verse.org/Verse:)int):void = 
                    var (local:)NewValue:(/C:)value = 
                            (/C/c:)_Value
                    case((local:)MemberName){
                        "A" => 
                                set (local:)NewValue.(/C/value:)A = (local:)MemberValue
                        "B" => 
                                set (local:)NewValue.(/C/value:)B = (local:)MemberValue
                        _ => {}
                    }
                    set (/C/c:)_Value = (local:)NewValue
        }
}

# This verse code was not correct, the "else" is indented to much,
# but we should be able to auto qualify it anyway.
# Before fix the else was printed as "else:;" which doesn't parse.
assert_auto_qualification(
vpackage(P0, /A):
  snippet:
     c := class:
       F(X:int)<transacts><decides>:void =
          if(X<20):
               if (X<10):
                    false?
               else:
               false?
){
(/A:)c := 
        class{
            (/A/c:)F((local:)X:(/Verse.org/Verse:)int)<transacts><decides>:void = 
                    
                    if{
                        (local:)X < 20
                    }
                    then {
                        
                        if{
                            (local:)X < 10
                        }
                        then {
                            false?
                        }
                        else {
                        }
                        false?
                    }
        }
}


# Workaround for compiler bug.
# The compiler accept:
#
#    @deprecated  c := class{}
#
# but fails on:
#
#    @deprecated (/path/to/:)c := class{}
#
# However the compiler accept
#
#    @deprecated
#    (/path/to/:)c := class{}
# 
assert_auto_qualification(
vpackage(P0, /Verse.org/Test, ?Scope:=InternalAPI):
  snippet:
    @deprecated c<public> := class() {}
){
@deprecated
(/Verse.org/Test:)c<public> := 
        class(){
        }
}


