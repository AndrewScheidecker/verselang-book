# No newlines after comparators, but ok after assignments
assert_auto_qualification(
vpackage(P0, /Path):
  snippet:
    F(X:int):void = 
        if (X < if (X = 10) {5} else {6}):
            X
        if (X = if (X = 10) {5} else {6}):
            X
        var Y:int = if (X = 10) {5} else {6}
        set Y = if (X = 10) {5} else {6}
        set Y += if (X = 10) {5} else {6}
){
(/Path:)F((local:)X:(/Verse.org/Verse:)int):void = 
        
        if{
            (local:)X < if{(local:)X = 10 } then {5 } else {6 }
        }
        then {
            (local:)X
        }
        
        if{
            (local:)X = if{(local:)X = 10 } then {5 } else {6 }
        }
        then {
            (local:)X
        }
        var (local:)Y:(/Verse.org/Verse:)int = 
                
                if{
                    (local:)X = 10
                }
                then {
                    5
                }
                else {
                    6
                }
        set (local:)Y = 
                if{
                    (local:)X = 10
                }
                then {
                    5
                }
                else {
                    6
                }
        set (local:)Y += 
                if{
                    (local:)X = 10
                }
                then {
                    5
                }
                else {
                    6
                }
}

