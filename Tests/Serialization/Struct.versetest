# Copyright Epic Games, Inc. All Rights Reserved.

using {/Verse.org/Tests/VerseTestScriptCmd}

# ============================================================================
# Struct definitions for testing
# ============================================================================

empty_struct := struct:

simple_struct := struct:
    A:int = 0

two_field_struct := struct:
    A:int = 0
    B:string = ""

nested_struct := struct:
    Inner:simple_struct = simple_struct{}
    Value:int = 0

struct_with_defaults := struct:
    A:int = 42
    B:string = "default"
    C:float = 3.14

# ============================================================================
# Classes for testing struct serialization
# ============================================================================

class_with_empty_struct := class(serializable_class):
    Value:empty_struct = empty_struct{}

class_with_simple_struct := class(serializable_class):
    Value:simple_struct = simple_struct{}

class_with_two_field_struct := class(serializable_class):
    Value:two_field_struct = two_field_struct{}

class_with_nested_struct := class(serializable_class):
    Value:nested_struct = nested_struct{}

class_with_struct_with_defaults := class(serializable_class):
    Value:struct_with_defaults = struct_with_defaults{}

# ============================================================================
# Versioned binary serialization roundtripping tests
# ============================================================================

# empty struct
assert{Instance := class_with_empty_struct{Value:=empty_struct{}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_empty_struct); true}

# simple struct
assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=0}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct); RoundtrippedInstance.Value.A = Instance.Value.A}
assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=42}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct); RoundtrippedInstance.Value.A = Instance.Value.A}
assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=-1}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct); RoundtrippedInstance.Value.A = Instance.Value.A}
assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=0x7fffffffffffffff}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct); RoundtrippedInstance.Value.A = Instance.Value.A}

# two field struct
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=0, B:=""}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=42, B:="hello"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=-100, B:="world"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=999, B:="你好"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}

# nested struct
assert{Instance := class_with_nested_struct{Value:=nested_struct{Inner:=simple_struct{A:=0}, Value:=0}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_struct); RoundtrippedInstance.Value.Inner.A = Instance.Value.Inner.A and RoundtrippedInstance.Value.Value = Instance.Value.Value}
assert{Instance := class_with_nested_struct{Value:=nested_struct{Inner:=simple_struct{A:=42}, Value:=100}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_struct); RoundtrippedInstance.Value.Inner.A = Instance.Value.Inner.A and RoundtrippedInstance.Value.Value = Instance.Value.Value}
assert{Instance := class_with_nested_struct{Value:=nested_struct{Inner:=simple_struct{A:=-1}, Value:=-1}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_struct); RoundtrippedInstance.Value.Inner.A = Instance.Value.Inner.A and RoundtrippedInstance.Value.Value = Instance.Value.Value}

# struct with defaults - test default values, partial changes, and full changes
assert{Instance := class_with_struct_with_defaults{Value:=struct_with_defaults{}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_struct_with_defaults); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B and RoundtrippedInstance.Value.C = Instance.Value.C}
assert{Instance := class_with_struct_with_defaults{Value:=struct_with_defaults{A:=0}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_struct_with_defaults); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B and RoundtrippedInstance.Value.C = Instance.Value.C}
assert{Instance := class_with_struct_with_defaults{Value:=struct_with_defaults{B:="changed"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_struct_with_defaults); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B and RoundtrippedInstance.Value.C = Instance.Value.C}
assert{Instance := class_with_struct_with_defaults{Value:=struct_with_defaults{A:=100, B:="new", C:=2.71}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_struct_with_defaults); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B and RoundtrippedInstance.Value.C = Instance.Value.C}

# ============================================================================
# Unversioned binary serialization roundtripping tests
# ============================================================================

assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=42}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value.A = Instance.Value.A}
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=42, B:="hello"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}
assert{Instance := class_with_nested_struct{Value:=nested_struct{Inner:=simple_struct{A:=42}, Value:=100}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_struct, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value.Inner.A = Instance.Value.Inner.A and RoundtrippedInstance.Value.Value = Instance.Value.Value}

# ============================================================================
# Text serialization roundtripping tests
# ============================================================================

assert{Instance := class_with_simple_struct{Value:=simple_struct{A:=42}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_simple_struct, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value.A = Instance.Value.A}
assert{Instance := class_with_two_field_struct{Value:=two_field_struct{A:=42, B:="hello"}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_two_field_struct, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value.A = Instance.Value.A and RoundtrippedInstance.Value.B = Instance.Value.B}
assert{Instance := class_with_nested_struct{Value:=nested_struct{Inner:=simple_struct{A:=42}, Value:=100}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_struct, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value.Inner.A = Instance.Value.Inner.A and RoundtrippedInstance.Value.Value = Instance.Value.Value}

# ============================================================================
# Tests of deserializing data serialized by old versions.
# ============================================================================

# Helper functions to generate test data - run these and copy the output to create tests.
# The output includes the expected value and the serialized data.
DumpSerializedSimpleStruct(Value:simple_struct):void=
    Instance := class_with_simple_struct{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingSimpleStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingSimpleStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingSimpleStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedTwoFieldStruct(Value:two_field_struct):void=
    Instance := class_with_two_field_struct{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingTwoFieldStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingTwoFieldStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingTwoFieldStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedNestedStruct(Value:nested_struct):void=
    Instance := class_with_nested_struct{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingNestedStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingNestedStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingNestedStruct[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

# Uncomment to generate test data:
<#>assert:
    DumpSerializedSimpleStruct(simple_struct{A:=0})
    DumpSerializedSimpleStruct(simple_struct{A:=42})
    DumpSerializedSimpleStruct(simple_struct{A:=-1})
    DumpSerializedSimpleStruct(simple_struct{A:=0x7fffffffffffffff})

<#>assert:
    DumpSerializedTwoFieldStruct(two_field_struct{A:=0, B:=""})
    DumpSerializedTwoFieldStruct(two_field_struct{A:=42, B:="hello"})
    DumpSerializedTwoFieldStruct(two_field_struct{A:=-100, B:="world"})

<#>assert:
    DumpSerializedNestedStruct(nested_struct{Inner:=simple_struct{A:=0}, Value:=0})
    DumpSerializedNestedStruct(nested_struct{Inner:=simple_struct{A:=42}, Value:=100})
    DumpSerializedNestedStruct(nested_struct{Inner:=simple_struct{A:=-1}, Value:=-1})

# Test helpers for deserializing old struct data
TestDeserializingSimpleStruct(ExpectedValue:simple_struct, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_simple_struct)
    if (DeserializedInstance.Value.A <> ExpectedValue.A):
        DebugPrint("Expected class_with_simple_struct\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_simple_struct\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingTwoFieldStruct(ExpectedValue:two_field_struct, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_two_field_struct)
    if (DeserializedInstance.Value.A <> ExpectedValue.A or DeserializedInstance.Value.B <> ExpectedValue.B):
        DebugPrint("Expected class_with_two_field_struct\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_two_field_struct\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingNestedStruct(ExpectedValue:nested_struct, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_nested_struct)
    if (DeserializedInstance.Value.Inner.A <> ExpectedValue.Inner.A or DeserializedInstance.Value.Value <> ExpectedValue.Value):
        DebugPrint("Expected class_with_nested_struct\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_nested_struct\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

