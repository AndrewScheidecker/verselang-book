using {/Verse.org/Tests/VerseTestScriptCmd}

# ============================================================================
# Tuple class definitions for testing
# (Tuples have the same Verse semantics as arrays, e.g. array{1, 2} = (1, 2))
# ============================================================================

class_with_tuple_int_int := class(serializable_class):
    Value:tuple(int, int) = (0, 0)

class_with_tuple_int_string := class(serializable_class):
    Value:tuple(int, string) = (0, "")

class_with_tuple_three := class(serializable_class):
    Value:tuple(int, string, float) = (0, "", 0.0)

class_with_nested_tuple := class(serializable_class):
    Value:tuple(int, tuple(int, int)) = (0, (0, 0))

# ============================================================================
# Versioned binary serialization roundtripping tests
# ============================================================================

# tuple(int, int)
assert{Instance := class_with_tuple_int_int{Value:=(0, 0)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_int{Value:=(1, 2)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_int{Value:=(-1, -2)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_int{Value:=(0x7fffffffffffffff, -9223372036854775808)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int); RoundtrippedInstance.Value = Instance.Value}

# tuple(int, string)
assert{Instance := class_with_tuple_int_string{Value:=(0, "")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_string{Value:=(42, "hello")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_string{Value:=(-1, "world")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_string{Value:=(100, "你好")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string); RoundtrippedInstance.Value = Instance.Value}

# tuple(int, string, float)
assert{Instance := class_with_tuple_three{Value:=(0, "", 0.0)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_three); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_three{Value:=(42, "hello", 3.14)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_three); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_three{Value:=(-1, "test", -1.5)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_three); RoundtrippedInstance.Value = Instance.Value}

# nested tuple
assert{Instance := class_with_nested_tuple{Value:=(0, (0, 0))}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_tuple); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_nested_tuple{Value:=(1, (2, 3))}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_tuple); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_nested_tuple{Value:=(-1, (-2, -3))}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_tuple); RoundtrippedInstance.Value = Instance.Value}

# ============================================================================
# Unversioned binary serialization roundtripping tests
# ============================================================================

assert{Instance := class_with_tuple_int_int{Value:=(1, 2)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_string{Value:=(42, "hello")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_three{Value:=(42, "hello", 3.14)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_three, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_nested_tuple{Value:=(1, (2, 3))}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_tuple, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# ============================================================================
# Text serialization roundtripping tests
# ============================================================================

assert{Instance := class_with_tuple_int_int{Value:=(1, 2)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_int, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_int_string{Value:=(42, "hello")}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_int_string, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_tuple_three{Value:=(42, "hello", 3.14)}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_tuple_three, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := class_with_nested_tuple{Value:=(1, (2, 3))}; RoundtrippedInstance := SerializeAndDeserialize(Instance, class_with_nested_tuple, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value = Instance.Value}

# ============================================================================
# Tests of deserializing data serialized by old versions.
# ============================================================================

# Helper functions to generate test data - run these and copy the output to create tests.
# The output includes the expected value and the serialized data.
DumpSerializedTupleIntInt(Value:tuple(int, int)):void=
    Instance := class_with_tuple_int_int{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingTupleIntInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingTupleIntInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingTupleIntInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedTupleIntString(Value:tuple(int, string)):void=
    Instance := class_with_tuple_int_string{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingTupleIntString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingTupleIntString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingTupleIntString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedTupleThree(Value:tuple(int, string, float)):void=
    Instance := class_with_tuple_three{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingTupleThree[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingTupleThree[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingTupleThree[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedNestedTuple(Value:tuple(int, tuple(int, int))):void=
    Instance := class_with_nested_tuple{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingNestedTuple[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingNestedTuple[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingNestedTuple[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

# Uncomment to generate test data:
<#>assert:
    DumpSerializedTupleIntInt((0, 0))
    DumpSerializedTupleIntInt((1, 2))
    DumpSerializedTupleIntInt((-1, -2))
    DumpSerializedTupleIntInt((0x7fffffffffffffff, -9223372036854775808))

<#>assert:
    DumpSerializedTupleIntString((0, ""))
    DumpSerializedTupleIntString((42, "hello"))
    DumpSerializedTupleIntString((-1, "world"))

<#>assert:
    DumpSerializedTupleThree((0, "", 0.0))
    DumpSerializedTupleThree((42, "hello", 3.14))

<#>assert:
    DumpSerializedNestedTuple((0, (0, 0)))
    DumpSerializedNestedTuple((1, (2, 3)))

# Test helpers for deserializing old tuple data
TestDeserializingTupleIntInt(ExpectedValue:tuple(int, int), SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_tuple_int_int)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected class_with_tuple_int_int\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_tuple_int_int\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingTupleIntString(ExpectedValue:tuple(int, string), SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_tuple_int_string)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected class_with_tuple_int_string\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_tuple_int_string\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingTupleThree(ExpectedValue:tuple(int, string, float), SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_tuple_three)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected class_with_tuple_three\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_tuple_three\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingNestedTuple(ExpectedValue:tuple(int, tuple(int, int)), SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, class_with_nested_tuple)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected class_with_nested_tuple\{Value:={DebugToString(ExpectedValue)}\}, but got class_with_nested_tuple\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

