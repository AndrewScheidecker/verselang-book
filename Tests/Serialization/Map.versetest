# ============================================================================

# int => int maps
assert{Instance := map_int_to_int{Value:=map{                        }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_int_to_int{Value:=map{1=>100                  }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_int_to_int{Value:=map{1=>10, 2=>20, 3=>30     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# int => string maps
assert{Instance := map_int_to_string{Value:=map{                     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_int_to_string{Value:=map{1=>"one", 2=>"two"   }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# string => int maps
assert{Instance := map_string_to_int{Value:=map{                     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_string_to_int{Value:=map{"key"=>42            }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# string => string maps
assert{Instance := map_string_to_string{Value:=map{                  }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_string, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_string_to_string{Value:=map{"hello"=>"world"  }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_string, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# char => int maps
assert{Instance := map_char_to_int{Value:=map{                       }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_char_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_char_to_int{Value:=map{'a'=>1, 'b'=>2         }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_char_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# logic => int maps
assert{Instance := map_logic_to_int{Value:=map{                      }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_logic_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_logic_to_int{Value:=map{true=>1, false=>0     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_logic_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# maps to arrays
assert{Instance := map_int_to_array_of_int{Value:=map{1=>array{10, 20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_array_of_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# maps to structs
assert{Instance := map_int_to_struct{Value:=map{1=>test_struct{A:=10, B:=20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_struct, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

# nested maps
assert{Instance := map_int_to_map_int_to_int{Value:=map{1=>map{10=>100}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}

