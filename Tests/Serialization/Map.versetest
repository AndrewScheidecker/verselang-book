# ============================================================================
# Delta serialization order change tests (UnversionedBinary)
# These tests verify that delta serialization correctly preserves key-value
# associations even when the serialization order may differ from the source.
# ============================================================================

# map_int_to_logic default is map{1=>true}
assert{Instance := map_int_to_logic{Value:=map{0=>false, 1=>true               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_logic, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default
assert{Instance := map_int_to_logic{Value:=map{0=>true, 1=>true, 2=>false      }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_logic, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # keys around default

# map_int_to_int default is map{42=>100}
assert{Instance := map_int_to_int{Value:=map{1=>1, 42=>100                     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default
assert{Instance := map_int_to_int{Value:=map{1=>1, 42=>100, 99=>99             }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # keys around default

# map_int_to_string default is map{1=>"hello"}
assert{Instance := map_int_to_string{Value:=map{0=>"zero", 1=>"hello"          }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# map_int_to_float default is map{1=>3.14}
assert{Instance := map_int_to_float{Value:=map{0=>0.0, 1=>3.14                 }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_float, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# map_logic_to_int default is map{true=>1, false=>0}
assert{Instance := map_logic_to_int{Value:=map{false=>0, true=>1               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_logic_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # same content, different order

# map_string_to_int default is map{"key"=>42}
assert{Instance := map_string_to_int{Value:=map{"a"=>1, "key"=>42              }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# Multi-entry maps with various orderings (UnversionedBinary)
assert{Instance := map_int_to_int{Value:=map{3=>30, 1=>10, 2=>20               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_int_to_float{Value:=map{3=>3.0, 1=>1.0, 2=>2.0          }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_float, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}
assert{Instance := map_int_to_string{Value:=map{3=>"c", 1=>"a", 2=>"b"         }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}
assert{Instance := map_char_to_int{Value:=map{'z'=>26, 'm'=>13, 'a'=>1         }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_char_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Nested maps with multiple entries (UnversionedBinary)
assert{Instance := map_int_to_map_int_to_int{Value:=map{2=>map{20=>200, 21=>210}, 1=>map{10=>100, 11=>110}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_map_int_to_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Maps to arrays with multiple entries (UnversionedBinary)
assert{Instance := map_int_to_array_of_int{Value:=map{3=>array{30}, 1=>array{10}, 2=>array{20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_array_of_int, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Maps to structs with multiple entries (UnversionedBinary)
assert{Instance := map_int_to_struct{Value:=map{3=>test_struct{A:=30}, 1=>test_struct{A:=10}, 2=>test_struct{A:=20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_struct, ?Mode:=serialization_mode.UnversionedBinary); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# ============================================================================
# Delta serialization order change tests (Text)
# These tests verify that delta serialization correctly preserves key-value
# associations even when the serialization order may differ from the source.
# ============================================================================

# map_int_to_logic default is map{1=>true}
assert{Instance := map_int_to_logic{Value:=map{0=>false, 1=>true               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_logic, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default
assert{Instance := map_int_to_logic{Value:=map{0=>true, 1=>true, 2=>false      }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_logic, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # keys around default

# map_int_to_int default is map{42=>100}
assert{Instance := map_int_to_int{Value:=map{1=>1, 42=>100                     }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default
assert{Instance := map_int_to_int{Value:=map{1=>1, 42=>100, 99=>99             }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # keys around default

# map_int_to_string default is map{1=>"hello"}
assert{Instance := map_int_to_string{Value:=map{0=>"zero", 1=>"hello"          }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# map_int_to_float default is map{1=>3.14}
assert{Instance := map_int_to_float{Value:=map{0=>0.0, 1=>3.14                 }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_float, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# map_logic_to_int default is map{true=>1, false=>0}
assert{Instance := map_logic_to_int{Value:=map{false=>0, true=>1               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_logic_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # same content, different order

# map_string_to_int default is map{"key"=>42}
assert{Instance := map_string_to_int{Value:=map{"a"=>1, "key"=>42              }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_string_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}  # add key before default

# Multi-entry maps with various orderings (Text)
assert{Instance := map_int_to_int{Value:=map{3=>30, 1=>10, 2=>20               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int, ?Mode:=serialization_mode.Text); RoundtrippedInstance.Value = Instance.Value}
assert{Instance := map_int_to_float{Value:=map{3=>3.0, 1=>1.0, 2=>2.0          }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_float, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}
assert{Instance := map_int_to_string{Value:=map{3=>"c", 1=>"a", 2=>"b"         }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}
assert{Instance := map_char_to_int{Value:=map{'z'=>26, 'm'=>13, 'a'=>1         }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_char_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Nested maps with multiple entries (Text)
assert{Instance := map_int_to_map_int_to_int{Value:=map{2=>map{20=>200, 21=>210}, 1=>map{10=>100, 11=>110}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_map_int_to_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Maps to arrays with multiple entries (Text)
assert{Instance := map_int_to_array_of_int{Value:=map{3=>array{30}, 1=>array{10}, 2=>array{20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_array_of_int, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# Maps to structs with multiple entries (Text)
assert{Instance := map_int_to_struct{Value:=map{3=>test_struct{A:=30}, 1=>test_struct{A:=10}, 2=>test_struct{A:=20}}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_struct, ?Mode:=serialization_mode.Text); MapsEqualUnordered[RoundtrippedInstance.Value, Instance.Value]}

# ============================================================================
# Tests of UE's ConvertFromType functionality to convert between compatible types on load.
# This behavior should not be visible to Verse users as the backward compatibility constraints should
# prevent them from making changes to incompatible types.
# ============================================================================

# Additional classes for conversion tests
map_char_to_char := class(serializable_class):
    Value:[char]char=map{'a'=>'A'}

<# These tests are just broken right now: they either assert or deserialize the default value.
bp_vm_only{
# [char]int --> [int]int (key conversion)
assert{Instance := map_char_to_int{Value:=map{                }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{}}
assert{Instance := map_char_to_int{Value:=map{'a'=>1          }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0x61=>1}}
assert{Instance := map_char_to_int{Value:=map{'a'=>1, 'b'=>2  }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0x61=>1, 0x62=>2}}
assert{Instance := map_char_to_int{Value:=map{0o00=>0, 0off=>255}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0=>0, -1=>255}} # 0xff sign extends to -1

# [char]string --> [int]string (key conversion)
assert{Instance := map_char_to_string{Value:=map{             }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string); RoundtrippedInstance.Value = map{}}
assert{Instance := map_char_to_string{Value:=map{'x'=>"x-ray" }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_string); RoundtrippedInstance.Value = map{0x78=>"x-ray"}}

# [logic]int --> [int]int (key conversion - logic to int)
assert{Instance := map_logic_to_int{Value:=map{               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{}}
assert{Instance := map_logic_to_int{Value:=map{false=>0       }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0=>0}}
assert{Instance := map_logic_to_int{Value:=map{true=>1        }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{1=>1}}
assert{Instance := map_logic_to_int{Value:=map{true=>1, false=>0}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{1=>1, 0=>0}}

# [int]logic --> [int]int (value conversion)
assert{Instance := map_int_to_logic{Value:=map{               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{}}
assert{Instance := map_int_to_logic{Value:=map{0=>false       }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0=>0}}
assert{Instance := map_int_to_logic{Value:=map{1=>true        }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{1=>1}}
assert{Instance := map_int_to_logic{Value:=map{0=>false, 1=>true}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0=>0, 1=>1}}

# [char]char --> [int]int (both key and value conversion)
assert{Instance := map_char_to_char{Value:=map{               }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{}}
assert{Instance := map_char_to_char{Value:=map{'a'=>'A'       }}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0x61=>0x41}}
assert{Instance := map_char_to_char{Value:=map{'a'=>'A', 'b'=>'B'}}; RoundtrippedInstance := SerializeAndDeserialize(Instance, map_int_to_int); RoundtrippedInstance.Value = map{0x61=>0x41, 0x62=>0x42}}
} #bp_vm_only
#>

# ============================================================================
# Tests of deserializing data serialized by old versions.
# ============================================================================

# Helper functions to generate test data - run these and copy the output to create tests.
# The output includes the expected value and the serialized data.
DumpSerializedMapIntToInt(Value:[int]int):void=
    Instance := map_int_to_int{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingMapIntToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingMapIntToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingMapIntToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedMapStringToInt(Value:[string]int):void=
    Instance := map_string_to_int{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingMapStringToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingMapStringToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingMapStringToInt[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

DumpSerializedMapIntToString(Value:[int]string):void=
    Instance := map_int_to_string{Value:=Value}
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.VersionedBinary)
        DebugPrint("assert\{TestDeserializingMapIntToString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.UnversionedBinary)
        DebugPrint("assert\{TestDeserializingMapIntToString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")
    block:
        SerializedData := Serialize(Instance, ?Mode:=serialization_mode.Text)
        DebugPrint("assert\{TestDeserializingMapIntToString[{DebugToString(Value)}, {DebugToString(SerializedData)}]\}")

# Uncomment to generate test data:
<#>assert:
    DumpSerializedMapIntToInt(map{})
    DumpSerializedMapIntToInt(map{0=>0})
    DumpSerializedMapIntToInt(map{1=>100})
    DumpSerializedMapIntToInt(map{-1=>-100})
    DumpSerializedMapIntToInt(map{1=>10, 2=>20, 3=>30})
    DumpSerializedMapIntToInt(map{0x7fffffffffffffff=>-1})

<#>assert:
    DumpSerializedMapStringToInt(map{})
    DumpSerializedMapStringToInt(map{"key"=>42})
    DumpSerializedMapStringToInt(map{"a"=>1, "b"=>2})

<#>assert:
    DumpSerializedMapIntToString(map{})
    DumpSerializedMapIntToString(map{1=>"one"})
    DumpSerializedMapIntToString(map{1=>"hello", 2=>"world"})

# Test helper for deserializing old map data
TestDeserializingMapIntToInt(ExpectedValue:[int]int, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, map_int_to_int)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected map_int_to_int\{Value:={DebugToString(ExpectedValue)}\}, but got map_int_to_int\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingMapStringToInt(ExpectedValue:[string]int, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, map_string_to_int)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected map_string_to_int\{Value:={DebugToString(ExpectedValue)}\}, but got map_string_to_int\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

TestDeserializingMapIntToString(ExpectedValue:[int]string, SerializedData:serialized_data)<decides>:void=
    DeserializedInstance := Deserialize(SerializedData, map_int_to_string)
    if (DeserializedInstance.Value <> ExpectedValue):
        DebugPrint("Expected map_int_to_string\{Value:={DebugToString(ExpectedValue)}\}, but got map_int_to_string\{Value:={DebugToString(DeserializedInstance.Value)}\}")
        false?

